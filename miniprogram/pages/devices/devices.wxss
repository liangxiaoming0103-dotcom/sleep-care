/* pages/devices/devices.wxss */

.devices-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f7fa 40%);
  padding: 20rpx 0 160rpx;
}

/* 设备列表 */
.device-list {
  padding: 0 28rpx;
}

/* 设备卡片 */
.device-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #6366f1;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 16rpx; right: 20rpx;
  width: 56rpx; height: 56rpx;
  font-size: 28rpx; line-height: 56rpx;
  text-align: center; opacity: 0.35;
  transition: all 0.15s;
}
.delete-btn:active { opacity: 1; transform: scale(1.2); }

/* 设备信息 */
.device-info {
  display: flex; flex-direction: column; gap: 10rpx;
  padding-right: 64rpx;
}
.device-nickname {
  font-size: 34rpx; font-weight: 700; color: #1e293b;
}
.device-serial {
  font-size: 24rpx; color: #94a3b8;
  font-family: 'Courier New', monospace;
}

/* 在线状态 */
.device-status {
  display: inline-flex; align-items: center; gap: 10rpx;
  margin-top: 8rpx; padding: 8rpx 20rpx;
  border-radius: 24rpx; align-self: flex-start;
}
.status-badge-online { background: #f0fdf4; }
.status-badge-offline { background: #f1f5f9; }
.status-dot {
  width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0;
}
.dot-online {
  background: #22c55e;
  box-shadow: 0 0 12rpx rgba(34,197,94,0.6);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { box-shadow:0 0 8rpx rgba(34,197,94,0.6); }
  50%     { box-shadow:0 0 20rpx rgba(34,197,94,0.9); }
}
.dot-offline { background: #cbd5e1; }
.status-text { font-size: 24rpx; font-weight: 600; color: #1e293b; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column;
  align-items: center; padding: 180rpx 0; gap: 20rpx;
}
.empty-icon { font-size: 88rpx; opacity: 0.25; }
.empty-text { font-size: 30rpx; color: #94a3b8; font-weight: 500; }
.empty-hint { font-size: 24rpx; color: #cbd5e1; }

/* 底部添加按钮 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: transparent;
}
.add-btn {
  width: 100%; height: 92rpx;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 46rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.3);
}
.add-btn:active {
  transform: scale(0.97); opacity: 0.9;
}
