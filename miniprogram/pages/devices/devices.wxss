/* pages/devices/devices.wxss */
/* 设备管理页面样式 — 医疗健康风格（蓝色系 + 灰色背景） */

/* =====================================================
   页面容器：浅灰背景，营造平静专业氛围
   ===================================================== */
.devices-container {
  min-height: 100vh;
  background-color: #f2f4f7;
  padding: 20rpx 0 160rpx;
}

/* =====================================================
   设备列表
   ===================================================== */
.device-list {
  padding: 0 28rpx;
}

/* =====================================================
   设备卡片：立体阴影 + 圆角，白色背景
   ===================================================== */
.device-card {
  position: relative;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx 30rpx;
  margin-bottom: 24rpx;
  /* 多层阴影增强立体感 */
  box-shadow:
    0 4rpx 20rpx rgba(0, 0, 0, 0.06),
    0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  /* 左侧蓝色装饰条 — 医疗风格点缀 */
  border-left: 6rpx solid #3b82f6;
}

/* =====================================================
   删除按钮：卡片右上角，低调半透明
   ===================================================== */
.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  font-size: 30rpx;
  line-height: 56rpx;
  text-align: center;
  opacity: 0.4;
  transition: all 0.15s;
}

.delete-btn:active {
  opacity: 1;
  transform: scale(1.2);
}

/* =====================================================
   设备信息
   ===================================================== */
.device-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-right: 64rpx;
}

/* 昵称：加粗、深色、较大 */
.device-nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

/* 序列号：等宽小字、浅灰 */
.device-serial {
  font-size: 24rpx;
  color: #94a3b8;
  font-family: 'Courier New', monospace;
}

/* =====================================================
   在线状态：徽章样式 + 圆点脉冲动画
   ===================================================== */
.device-status {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  align-self: flex-start;
}

/* 在线徽章：浅绿底 */
.status-badge-online {
  background-color: #f0fdf4;
}

/* 离线徽章：浅灰底 */
.status-badge-offline {
  background-color: #f1f5f9;
}

/* 圆点 */
.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

/* 🟢 在线圆点 — 绿色 + 发光 + 脉冲外圈 */
.dot-online {
  background-color: #22c55e;
  box-shadow: 0 0 12rpx rgba(34, 197, 94, 0.6);
  animation: pulse 2s ease-in-out infinite;
}

/* 脉冲动画：模拟呼吸灯效果 */
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 8rpx rgba(34, 197, 94, 0.6); }
  50%      { box-shadow: 0 0 20rpx rgba(34, 197, 94, 0.9); }
}

/* ⚪ 离线圆点 — 灰色无动画 */
.dot-offline {
  background-color: #cbd5e1;
}

/* 状态文字 */
.status-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
}

/* =====================================================
   空状态
   ===================================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 88rpx;
  opacity: 0.25;
}

.empty-text {
  font-size: 30rpx;
  color: #94a3b8;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #cbd5e1;
}

/* =====================================================
   底部操作栏
   ===================================================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #f2f4f7;
}

/* 添加按钮：医疗蓝、圆角、按压反馈 */
.add-btn {
  width: 100%;
  height: 92rpx;
  background-color: #3b82f6;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 按钮阴影增强立体 */
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.35);
  transition: all 0.15s ease;
}

.add-btn:active {
  background-color: #2563eb;
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.25);
}