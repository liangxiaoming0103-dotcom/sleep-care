<!-- pages/doctors/doctors.wxml — 医生授权页面 -->
<view class="container">
  <!-- 授权区域 -->
  <view class="grant-section">
    <view class="section-title">添加医生授权</view>
    <view class="grant-form">
      <input
        class="phone-input"
        type="text"
        placeholder="请输入医生手机号"
        value="{{doctorPhone}}"
        bindinput="onPhoneInput"
      />
      <button class="grant-btn" bindtap="grantDoctor">授权</button>
    </view>
    <view class="grant-hint">医生确认后即可查看您的睡眠数据</view>
  </view>

  <!-- 已授权列表 -->
  <view class="list-section">
    <view class="section-title">已授权医生</view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:elif="{{grantedList.length === 0}}" class="empty">暂无授权记录</view>
    <view wx:else class="doctor-list">
      <view
        class="doctor-card"
        wx:for="{{grantedList}}"
        wx:key="id"
      >
        <view class="doctor-info">
          <view class="doctor-name">{{item.doctor_name || '医生'}}</view>
          <view class="doctor-phone">{{item.doctor_phone}}</view>
          <view class="doctor-status {{item.status}}">
            {{item.status === 'pending' ? '待确认' : '已授权'}}
          </view>
        </view>
        <view class="doctor-expire">有效期至 {{item.expire_date}}</view>
        <button
          class="revoke-btn"
          data-doctor-id="{{item.doctor_id}}"
          bindtap="revokeGrant"
        >撤销授权</button>
      </view>
    </view>
  </view>
</view>
