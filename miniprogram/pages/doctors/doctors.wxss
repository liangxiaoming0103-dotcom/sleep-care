/* pages/doctors/doctors.wxss — 医生授权页面样式（主题：indigo 医疗风） */

/* 页面容器 */
.container {
  background: #f5f7fa;
  padding: 16px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部标题 */
.page-header {
  margin-bottom: 20px;
}
.page-title {
  font-size: 18px;
  font-weight: 700;
  color: #1e293b;
}

/* 加载 / 空状态 */
.loading,
.empty {
  text-align: center;
  padding: 60px 0;
  color: #94a3b8;
  font-size: 14px;
}

/* ========== 医生卡片 ========== */
.doctor-card {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 左侧信息区 */
.card-info {
  flex: 1;
}

.card-name {
  font-size: 16px;
  font-weight: 700;
  color: #1e293b;
}

.card-phone {
  font-size: 14px;
  color: #64748b;
  margin-top: 4px;
}

.card-expire {
  font-size: 12px;
  color: #94a3b8;
  margin-top: 4px;
}

/* 状态标签 */
.card-status {
  display: inline-block;
  font-size: 12px;
  padding: 2px 10px;
  border-radius: 10px;
  margin-top: 6px;
}
.card-status.pending {
  background: #fef3c7;
  color: #b45309;
}
.card-status.active {
  background: #dcfce7;
  color: #166534;
}

/* 撤销按钮 */
.revoke-btn {
  color: #ef4444;
  font-size: 14px;
  background: #fff;
  border: 1px solid #fecaca;
  border-radius: 8px;
  padding: 8px 16px;
  line-height: 1.2;
}

/* ========== 底部添加区域 ========== */
.add-section {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 16px;
  margin-top: 16px;
  border-top: 1px solid #e2e8f0;
}

.phone-input {
  flex: 1;
  height: 44px;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  background: #fff;
}

.add-btn {
  width: 80px;
  height: 44px;
  line-height: 44px;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  font-size: 14px;
  border-radius: 8px;
  padding: 0;
  text-align: center;
  border: none;
  box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}
