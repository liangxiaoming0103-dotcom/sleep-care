/* pages/doctors/doctors.wxss — 医生授权页面样式 */
.container {
  padding: 20rpx 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 授权区域 */
.grant-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2c3e;
  margin-bottom: 24rpx;
}

.grant-form {
  display: flex;
  gap: 20rpx;
}

.phone-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.grant-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #2c7da0;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.grant-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 已授权列表 */
.list-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.loading, .empty {
  text-align: center;
  padding: 60rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.doctor-card {
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.doctor-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2c3e;
}

.doctor-phone {
  font-size: 26rpx;
  color: #64748b;
}

.doctor-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.doctor-status.pending {
  background: #fef3c7;
  color: #92400e;
}

.doctor-status.active {
  background: #dcfce7;
  color: #166534;
}

.doctor-expire {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.revoke-btn {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #fca5a5;
  border-radius: 12rpx;
  font-size: 26rpx;
}
