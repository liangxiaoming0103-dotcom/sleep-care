/* pages/home/home.wxss */
/* 首页样式 — 医疗健康睡眠主题 */

/* =====================================================
   页面容器
   ===================================================== */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f7fa 40%);
  display: flex;
  flex-direction: column;
  padding: 0 28rpx;
}

/* =====================================================
   状态提示
   ===================================================== */
.status-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-icon-circle {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 56rpx;
  background: #eef2ff;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 30rpx;
  color: #64748b;
  font-weight: 500;
}

.status-hint {
  font-size: 24rpx;
  color: #94a3b8;
}

/* =====================================================
   可滚动内容区
   ===================================================== */
.report-scroll {
  padding: 40rpx 0 60rpx;
}

/* =====================================================
   问候栏
   ===================================================== */
.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 36rpx;
  padding: 0 8rpx;
}

.greeting-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.greeting-sub {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  display: block;
}

.greeting-date {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.date-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

/* =====================================================
   睡眠评分卡片
   ===================================================== */
.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(145deg, #4f46e5, #6366f1, #818cf8);
  border-radius: 32rpx;
  padding: 48rpx 40rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.3);
}

/* 环形评分 */
.score-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: inset 0 0 0 4rpx rgba(255,255,255,0.2);
}

.score-number {
  font-size: 80rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.score-unit {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 2rpx;
}

.score-level {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  letter-spacing: 4rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 6rpx 28rpx;
}

/* =====================================================
   三列指标
   ===================================================== */
.metrics-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.metric-icon-box {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 36rpx;
  border-radius: 20rpx;
  margin-bottom: 14rpx;
}

.icon-blue   { background: #eff6ff; }
.icon-purple { background: #f5f3ff; }
.icon-orange { background: #fff7ed; }

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.2;
}

.metric-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  white-space: nowrap;
}

/* =====================================================
   睡眠结构卡片
   ===================================================== */
.stage-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stage-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
}

/* 比例条 */
.stage-bar {
  display: flex;
  height: 28rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.stage-segment.deep  { background: #6366f1; }
.stage-segment.rem   { background: #a78bfa; }
.stage-segment.light { background: #c7d2fe; }
.stage-segment.awake { background: #fde68a; }

/* 图例 */
.stage-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 4rpx;
}

.deep-dot  { background: #6366f1; }
.rem-dot   { background: #a78bfa; }
.light-dot { background: #c7d2fe; }
.awake-dot { background: #fde68a; }

/* =====================================================
   查看详细分期按钮
   ===================================================== */
.go-report-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.3);
}

.settings-entry {
  margin-top: 28rpx;
}

.settings-entry button {
  background: #ffffff;
  color: #6366f1;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: 2rpx solid #e0e7ff;
  padding: 18rpx 0;
}