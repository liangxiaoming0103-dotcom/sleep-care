<!--pages/login/login.wxml-->
<!-- 登录页面：手机号 + 密码登录，调用云后台 /api/auth/login -->

<view class="login-container">
  <!-- 顶部标题 -->
  <view class="title-section">
    <text class="title">智能睡眠管理</text>
    <text class="subtitle">您的私人睡眠助手</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 手机号输入框 -->
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="inputPhone"
      />
    </view>

    <!-- 密码输入框 -->
    <view class="input-group">
      <text class="input-label">密码</text>
      <input
        class="input-field"
        type="password"
        placeholder="请输入密码"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="inputPassword"
      />
    </view>

    <!-- 登录按钮 -->
    <button class="login-btn" bindtap="handleLogin">登录</button>

    <!-- 底部提示 -->
    <view class="hint-section">
      <text class="hint-text">固定密码：123456</text>
    </view>
  </view>
</view>