<!--pages/login/login.wxml-->
<!-- 登录页面：手机号 + 密码登录 -->

<view class="container">
  <!-- 顶部品牌区 -->
  <view class="hero">
    <view class="hero-icon">🌙</view>
    <text class="hero-title">智能睡眠管理</text>
    <text class="hero-sub">您的私人睡眠助手</text>
  </view>

  <!-- 登录卡片 -->
  <view class="card">
    <!-- 手机号 -->
    <view class="field">
      <text class="field-icon">📱</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="inputPhone"
      />
    </view>

    <!-- 密码 -->
    <view class="field">
      <text class="field-icon">🔒</text>
      <input
        class="field-input"
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="inputPassword"
      />
    </view>

    <!-- 登录按钮 -->
    <button class="btn" bindtap="handleLogin">登 录</button>

    <!-- 底部链接 -->
    <view class="footer">
      <text class="footer-hint">固定密码：123456</text>
      <text class="footer-link" bindtap="goRegister">没有账号？去注册 ›</text>
    </view>
  </view>
</view>
