<!--pages/register/register.wxml-->
<!-- 注册页面：昵称 + 手机号 + 密码 + 确认密码，调用 /api/auth/register -->

<view class="register-container">
  <!-- 顶部返回 -->
  <view class="top-back" bindtap="goBack">
    <text class="back-arrow">‹</text>
    <text>返回</text>
  </view>

  <!-- 顶部标题 -->
  <view class="title-section">
    <text class="title">创建账号</text>
    <text class="subtitle">注册智能睡眠管理账号</text>
  </view>

  <!-- 注册表单 -->
  <view class="form-section">
    <!-- 昵称输入框 -->
    <view class="input-group">
      <text class="input-label">昵称</text>
      <input
        class="input-field"
        type="text"
        placeholder="请输入昵称"
        placeholder-class="placeholder"
        value="{{nickname}}"
        bindinput="inputNickname"
      />
    </view>

    <!-- 手机号输入框 -->
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="inputPhone"
      />
    </view>

    <!-- 密码输入框 -->
    <view class="input-group">
      <text class="input-label">密码</text>
      <input
        class="input-field"
        type="password"
        placeholder="请输入密码（至少6位）"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="inputPassword"
      />
    </view>

    <!-- 确认密码输入框 -->
    <view class="input-group">
      <text class="input-label">确认密码</text>
      <input
        class="input-field"
        type="password"
        placeholder="请再次输入密码"
        placeholder-class="placeholder"
        value="{{password2}}"
        bindinput="inputPassword2"
      />
    </view>

    <!-- 注册按钮 -->
    <button class="register-btn" bindtap="handleRegister">注册</button>

    <!-- 底部提示 -->
    <view class="hint-section">
      <text class="hint-text">已有账号？前往登录</text>
    </view>
  </view>
</view>
