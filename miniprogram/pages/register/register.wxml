<!--pages/register/register.wxml-->
<!-- 注册页面：昵称 + 手机号 + 密码 + 确认密码 -->

<view class="container">
  <!-- 顶部品牌区 -->
  <view class="hero">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <view class="hero-icon">✨</view>
    <text class="hero-title">创建账号</text>
    <text class="hero-sub">开启您的睡眠管理之旅</text>
  </view>

  <!-- 注册卡片 -->
  <view class="card">
    <!-- 昵称 -->
    <view class="field">
      <text class="field-icon">👤</text>
      <input
        class="field-input"
        type="text"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="inputNickname"
      />
    </view>

    <!-- 手机号 -->
    <view class="field">
      <text class="field-icon">📱</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入11位手机号"
        value="{{phone}}"
        bindinput="inputPhone"
      />
    </view>

    <!-- 密码 -->
    <view class="field">
      <text class="field-icon">🔒</text>
      <input
        class="field-input"
        type="password"
        placeholder="请设置密码（至少6位）"
        value="{{password}}"
        bindinput="inputPassword"
      />
    </view>

    <!-- 确认密码 -->
    <view class="field">
      <text class="field-icon">✓</text>
      <input
        class="field-input"
        type="password"
        placeholder="请再次输入密码"
        value="{{password2}}"
        bindinput="inputPassword2"
      />
    </view>

    <!-- 注册按钮 -->
    <button class="btn" bindtap="handleRegister">注 册</button>

    <!-- 底部链接 -->
    <view class="footer">
      <text class="footer-link" bindtap="goLogin">已有账号？前往登录 ›</text>
    </view>
  </view>
</view>
