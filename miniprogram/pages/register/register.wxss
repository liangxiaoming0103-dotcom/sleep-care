/* pages/register/register.wxss */
/* 注册页面 — 与登录页共享靛蓝设计语言 */

/* ===== 容器 ===== */
.container {
  width: 100vw;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f3ff 40%, #fafafa 100%);
  padding: 0 56rpx;
  box-sizing: border-box;
}

/* ===== 品牌区 ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  position: relative;
  width: 100%;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: -12rpx;
  top: 8rpx;
  font-size: 30rpx;
  color: #6366f1;
  font-weight: 700;
  padding: 8rpx 16rpx;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1e1b4b;
  letter-spacing: 2rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: #a5b4fc;
  margin-top: 10rpx;
  letter-spacing: 4rpx;
}

/* ===== 卡片 ===== */
.card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 44rpx 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(79, 70, 229, 0.08);
}

/* ===== 输入域 ===== */
.field {
  display: flex;
  align-items: center;
  background: #f5f7fe;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.field:focus-within {
  border-color: #818cf8;
  background: #fff;
}

.field-icon {
  font-size: 34rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 92rpx;
  font-size: 30rpx;
  color: #1e1b4b;
}

/* placeholder 颜色 */
.field-input::placeholder {
  color: #c7d2fe;
}

/* ===== 按钮 ===== */
.btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  margin-top: 12rpx;
  letter-spacing: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.30);
}

.btn:active {
  background: linear-gradient(135deg, #4f46e5, #4338ca);
  transform: scale(0.98);
}

/* ===== 底部 ===== */
.footer {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.footer-link {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 600;
}

.footer-link:active {
  color: #4f46e5;
}
