/* pages/report/report.wxss */
/* 睡眠分期报告页 — 配色与首页统一 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f7fa 40%);
  padding: 25rpx 28rpx 60rpx;
}

/* =====================================================
   加载 / 空状态
   ===================================================== */
.loading-box, .empty-box {
  flex: 1; display: flex; flex-direction: column;
  justify-content: center; align-items: center; gap: 20rpx;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e2e8f0; border-top-color: #6366f1;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #94a3b8; }
.empty-text { font-size: 30rpx; color: #64748b; font-weight: 500; }
.empty-hint { font-size: 24rpx; color: #94a3b8; }
.empty-icon-circle {
  width: 120rpx; height: 120rpx; line-height: 120rpx;
  text-align: center; font-size: 56rpx;
  background: #eef2ff; border-radius: 50%;
}

/* =====================================================
   日期导航
   ===================================================== */
.date-nav {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; border-radius: 24rpx;
  padding: 20rpx 28rpx; margin: 0 0 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.nav-arrow {
  width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #6366f1;
  background: #eef2ff; border-radius: 50%;
}
.nav-arrow:active { background: #e0e7ff; }
.nav-disabled { opacity: 0.25; pointer-events: none; }
.date-center {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.date-main { font-size: 36rpx; font-weight: 700; color: #1e293b; }
.date-sub  { font-size: 22rpx; color: #94a3b8; }

/* =====================================================
   标题卡片（渐变 hero）
   ===================================================== */
.hero-card {
  background: linear-gradient(135deg, #4f46e5, #6366f1, #818cf8);
  border-radius: 28rpx;
  padding: 36rpx 28rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(79,70,229,0.3);
}
.hero-title {
  display: block; text-align: center;
  font-size: 36rpx; font-weight: 700; color: #fff;
}
.hero-hint {
  display: block; text-align: center;
  font-size: 22rpx; color: rgba(255,255,255,0.7);
  margin-top: 6rpx; margin-bottom: 28rpx;
}
.hero-stats {
  display: flex; justify-content: space-around;
}
.hero-stat {
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
}
.hero-num {
  width: 88rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; border-radius: 50%;
  font-size: 36rpx; font-weight: 700; color: #fff;
  background: rgba(255,255,255,0.18);
}
.hero-label { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* =====================================================
   通用卡片 & 标题
   ===================================================== */
.chart-card, .ratio-card, .bar-card {
  background: #fff; border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx; font-weight: 700; color: #1e293b;
  display: block; margin-bottom: 16rpx;
}

/* 图例 */
.chart-legend {
  display: flex; justify-content: center; gap: 28rpx; margin-bottom: 20rpx;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: #64748b; }
.ldot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.ldot-awake { background: #fde68a; }
.ldot-light { background: #c7d2fe; }
.ldot-deep  { background: #6366f1; }
.ldot-rem   { background: #a78bfa; }

/* =====================================================
   卡片1：hypnogram 横向色块条
   ===================================================== */
.stage-scroll { width: 100%; white-space: nowrap; }
.stage-track {
  display: flex; height: 56rpx;
  border-radius: 14rpx; overflow: hidden;
  background: #f1f5f9;
}
.stage-block {
  flex-shrink: 0; width: 14rpx; height: 56rpx;
}
.s0 { background: #fde68a; }
.s1 { background: #c7d2fe; }
.s2 { background: #6366f1; }
.s3 { background: #a78bfa; }

.stage-labels { display: flex; margin-top: 10rpx; }
.stage-label-slot { flex-shrink: 0; width: 14rpx; }
.stage-label-text { font-size: 18rpx; color: #94a3b8; }

/* =====================================================
   卡片2：Y轴柱状图
   ===================================================== */
.bar-body {
  display: flex;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx 12rpx 8rpx 8rpx;
}
.y-axis {
  display: flex; flex-direction: column;
  justify-content: space-between;
  padding: 0 14rpx 42rpx 0;
  font-size: 20rpx; color: #94a3b8; font-weight: 500;
  width: 56rpx; text-align: right; flex-shrink: 0;
}
.bar-scroll { flex: 1; overflow-x: auto; white-space: nowrap; }
.bar-row {
  display: flex; align-items: flex-end;
  height: 180rpx; gap: 4rpx; padding: 0 4rpx;
}
.bar-col {
  flex-shrink: 0; width: 18rpx;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.bar {
  width: 18rpx; border-radius: 5rpx 5rpx 2rpx 2rpx;
}
.b0 { background: #fde68a; box-shadow: 0 2rpx 6rpx rgba(253,230,138,0.4); }
.b1 { background: #c7d2fe; box-shadow: 0 2rpx 6rpx rgba(199,210,254,0.4); }
.b2 { background: #6366f1; box-shadow: 0 2rpx 6rpx rgba(99,102,241,0.4); }
.b3 { background: #a78bfa; box-shadow: 0 2rpx 6rpx rgba(167,139,250,0.4); }

.bar-labels { display: flex; margin-top: 10rpx; }
.bar-label-col { flex-shrink: 0; width: 22rpx; }
.bar-label-text { font-size: 18rpx; color: #94a3b8; }

/* =====================================================
   卡片3：占比条
   ===================================================== */
.ratio-bar {
  display: flex; height: 32rpx;
  border-radius: 16rpx; overflow: hidden;
  margin: 20rpx 0 16rpx;
}
.ratio-seg { min-width: 4rpx; }
.r-awake { background: #fde68a; }
.r-light { background: #c7d2fe; }
.r-deep  { background: #6366f1; }
.r-rem   { background: #a78bfa; }
.ratio-labels {
  display: flex; justify-content: space-between;
  font-size: 24rpx; color: #64748b;
}

/* =====================================================
   视图切换标签
   ===================================================== */
/* =====================================================
   视图切换标签（三段式 Segmented Control）
   ===================================================== */
.tab-bar {
  display: flex;
  background: #f1f5f9;
  border-radius: 24rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  border-radius: 20rpx;
  position: relative;
  z-index: 1;
}

.tab-item:active { opacity: 0.8; }

.tab-active {
  background: #fff;
  color: #4f46e5;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08), 0 1rpx 3rpx rgba(0,0,0,0.04);
}

/* =====================================================
   趋势子切换（日/周/月 分段按钮）
   ===================================================== */
.subtab-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.subtab-item {
  flex: 1;
  text-align: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #64748b;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.subtab-item:active { opacity: 0.8; }

.subtab-active {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(79,70,229,0.25);
}

/* =====================================================
   趋势柱状图
   ===================================================== */
.trend-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.trend-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.trend-avg-tag {
  font-size: 24rpx;
  color: #94a3b8;
}

.trend-avg-tag text {
  font-size: 36rpx;
  font-weight: 700;
  color: #6366f1;
}

/* 柱状图区 */
.trend-row {
  height: 200rpx;
  align-items: flex-end;
  gap: 24rpx;
  padding: 0 6rpx;
  position: relative;
}

/* 均分参考线 */
.trend-avg-line {
  position: absolute;
  left: -8rpx; right: -8rpx;
  height: 1px;
  background: #f87171;
  z-index: 2;
  pointer-events: none;
  opacity: 0.4;
}

.trend-avg-label {
  position: absolute;
  right: 6rpx;
  top: -15rpx;
  font-size: 18rpx;
  color: #f87171;
  font-weight: 500;
  background: #fff;
  padding: 0 6rpx;
}

.trend-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  width: 80rpx;
  height: 200rpx;
}

.trend-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 6rpx;
}

.trend-bar {
  width: 40rpx;
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  min-height: 4rpx;
  background: #a5b4fc;
}

.trend-label-col {
  width: 104rpx;
  text-align: center;
}

.bar-label-text {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 500;
}

/* =====================================================
   噪音曲线
   ===================================================== */
.noise-card {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.noise-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2c3e;
  display: block;
  margin-bottom: 10rpx;
}

.noise-subtitle {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
}

.noise-body {
  display: flex;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx 12rpx 8rpx 8rpx;
}

.y-axis-db {
  width: 60rpx;
}

/* 噪音柱状密集图（144 根细柱模拟曲线） */
.noise-row {
  display: flex;
  align-items: flex-end;
  height: 180rpx;
  gap: 1rpx;
}

.noise-bar {
  flex-shrink: 0;
  width: 4rpx;
  min-height: 2rpx;
  background: #6366f1;
  border-radius: 2rpx 2rpx 0 0;
  opacity: 0.7;
}

.noise-labels {
  display: flex;
  margin-top: 10rpx;
}

.noise-label-col {
  flex-shrink: 0;
  width: 5rpx;
}

.noise-label-text {
  font-size: 18rpx;
  color: #94a3b8;
}

/* =====================================================
   医生建议卡片
   ===================================================== */
.advice-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 32rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  min-height: 120rpx;
}

/* 模块分隔线 */
.section-divider {
  width: 60%;
  height: 2rpx;
  background: #e2e8f0;
  margin: 0 auto 24rpx;
}
.advice-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.advice-icon {
  width: 44rpx; height: 44rpx; line-height: 44rpx;
  text-align: center;
  font-size: 26rpx;
  background: #eef2ff;
  border-radius: 12rpx;
}
.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}
.advice-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: auto;
}
.advice-content {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
  white-space: pre-wrap;
}
.advice-empty {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}
.advice-action {
  display: inline-block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 600;
}
