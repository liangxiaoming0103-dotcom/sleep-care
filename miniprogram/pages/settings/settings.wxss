/* pages/settings/settings.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f7fa 40%);
  padding: 0 28rpx 60rpx;
}

/* 顶部返回 */
.top-bar {
  text-align: left;
  padding: 20rpx 0 12rpx;
}
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 600;
  padding: 8rpx 0;
}

/* 加载 */
.loading-box {
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  padding-top: 200rpx; gap: 24rpx;
}
.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e2e8f0; border-top-color: #6366f1;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #94a3b8; }

/* 分区标签 */
.section-label {
  font-size: 26rpx; color: #94a3b8; font-weight: 700;
  margin: 32rpx 0 16rpx 4rpx;
}

/* 卡片容器 */
.card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.card-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 28rpx;
}
.card-item + .card-item {
  border-top: 1rpx solid #f1f5f9;
}
.card-item-col {
  padding: 28rpx 28rpx 20rpx;
  border-top: 1rpx solid #f1f5f9;
}
.card-label {
  font-size: 30rpx; color: #334155; font-weight: 600;
  flex-shrink: 0;
}
.card-input {
  font-size: 28rpx; color: #475569;
  text-align: right; flex: 1; padding: 4rpx 0;
}
.card-picker {
  font-size: 28rpx; font-weight: 600; color: #6366f1;
  background: #eef2ff; border-radius: 16rpx;
  padding: 10rpx 24rpx;
}

/* 性别 */
.gender-row { display: flex; gap: 12rpx; }
.gender-opt {
  font-size: 26rpx; color: #64748b;
  padding: 10rpx 28rpx; border-radius: 20rpx;
  background: #f1f5f9;
}
.gender-opt.gender-active {
  background: #6366f1; color: #fff; font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.25);
}

/* 滑块 */
.slider-top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8rpx;
}
.slider-num {
  font-size: 28rpx; font-weight: 700; color: #6366f1;
}
.slider-range {
  display: flex; justify-content: space-between;
  font-size: 22rpx; color: #94a3b8; margin-top: 2rpx;
}

/* 按钮 */
.btn-primary,
.btn-outline {
  width: 100%; border-radius: 20rpx; border: none;
  font-size: 30rpx; font-weight: 700; padding: 24rpx 0;
  margin-top: 20rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(99,102,241,0.25);
}
.btn-outline {
  background: #eef2ff;
  color: #4f46e5;
}
