/* pages/settings/settings.wxss */
/* 作息设置页 */

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40rpx;
}

/* 加载 */
.loading-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-top: 200rpx;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 28rpx; color: #999; }

/* =====================================================
   设置卡片
   ===================================================== */
.setting-item {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: box-shadow 0.2s;
}

.setting-item:active {
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* 纵向布局（滑块用） */
.setting-item-col {
  flex-direction: column;
  align-items: stretch;
}

.setting-item-col .label {
  margin-bottom: 16rpx;
}

/* =====================================================
   标签
   ===================================================== */
.label {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  flex-shrink: 0;
}

/* =====================================================
   时间选择器
   ===================================================== */
.picker-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A90D9;
  background: linear-gradient(135deg, #f0f5fb, #e8f0fa);
  border-radius: 18rpx;
  padding: 16rpx 28rpx;
  letter-spacing: 1rpx;
  border: 1rpx solid rgba(74,144,217,0.15);
}

/* =====================================================
   日出模拟滑块
   ===================================================== */
.slider-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.slider-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #4A90D9;
}

.slider-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.slider-body slider {
  flex: 1;
}

.slider-min,
.slider-max {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  width: 28rpx;
  text-align: center;
}

/* =====================================================
   保存按钮
   ===================================================== */
.save-btn {
  width: 100%;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4A90D9, #5ba0e8);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 26rpx 0;
  margin-top: 40rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.3);
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
